-- 1. Fetch employees whose salary is higher than the department average

SELECT id, emp_name, department, salary FROM employees e WHERE salary > ( SELECT AVG(salary) FROM employees WHERE department = e.department );
                                                                                 
-- 2. Use a subquery to list customers who placed more than 2 orders

SELECT customer_id, customer_name FROM customers WHERE customer_id IN (SELECT customer_id FROM orders GROUP BY customer_id HAVING COUNT(*) > 2);
																
-- 3. Fetch the highest-priced product using a subquery in WHERE

SELECT * FROM product WHERE price = (SELECT MAX(price) FROM product);

-- 4. Create a subquery that returns the total order value per customer

SELECT c.customer_id, c.customer_name, (SELECT SUM(o.order_amount) FROM orders o WHERE o.customer_id = c.customer_id) AS total_order_value FROM customers c;

-- 5. Use a correlated subquery to list employees earning more than their manager

SELECT e.id, e.name, e.salary FROM employees3 e WHERE e.salary > (SELECT m.salary FROM employees3 m WHERE m.id = e.manager_id);

-- 6. Check if a product exists in the orders table using EXISTS

SELECT product_id, product_name FROM product p WHERE EXISTS (SELECT 1 FROM order1 o WHERE o.product_id = p.product_id);
