-- 1. Create sales table
  
CREATE TABLE sales ( id INT PRIMARY KEY, product VARCHAR(50), amount INT);

-- Insert sample data

INSERT INTO sales VALUES(1,'Laptop',50000),(2,'Mobile',30000),(3,'Watch',15000),(4,'Tablet',30000),(5,'Shoes',10000);

-- 2. ROW_NUMBER()

SELECT product, amount,ROW_NUMBER() OVER(ORDER BY amount DESC) AS row_num FROM sales;

-- 3. RANK()

SELECT product, amount,RANK() OVER(ORDER BY amount DESC) AS rank_num FROM sales;

-- 4. DENSE_RANK()

SELECT product, amount,DENSE_RANK() OVER(ORDER BY amount DESC) AS dense_rank_num FROM sales;

-- 5. Running Total using SUM() OVER()

SELECT product, amount, SUM(amount) OVER(ORDER BY id) AS running_total FROM sales;

-- 6. CTE for sales above average

WITH avg_sales AS (
    SELECT AVG(amount) AS avg_amount
    FROM sales
)

SELECT * FROM sales WHERE amount > ( SELECT avg_amount FROM avg_sales );
