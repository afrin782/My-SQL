-- 1. Create tables customers and orders

CREATE TABLE customers ( customer_id INT PRIMARY KEY,
                         customer_name VARCHAR(50) );

CREATE TABLE orders ( order_id INT PRIMARY KEY,
                      product_name VARCHAR(50),
                      customer_id INT,
                      FOREIGN KEY (customer_id) REFERENCES customers(customer_id) );

-- 2. Insert 5 customers and 5 orders

INSERT INTO customers VALUES(1,'Asha'), (2,'Rahul'), (3,'Meena'), (4,'John'), (5,'Sara');

INSERT INTO orders VALUES(101,'Laptop',1),(102,'Mobile',2),(103,'Tablet',1),(104,'Watch',3),(105,'Shoes',5);

-- 3. INNER JOIN

SELECT customers.customer_name, orders.product_name FROM customers INNER JOIN orders ON customers.customer_id = orders.customer_id;

-- 4. LEFT JOIN

SELECT customers.customer_name, orders.product_name FROM customers LEFT JOIN orders ON customers.customer_id = orders.customer_id;

