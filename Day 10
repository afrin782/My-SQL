-- 1. Create a stored procedure to insert a new employee

DELIMITER //
CREATE PROCEDURE InsertEmployee1(
    IN p_id INT,
    IN p_name VARCHAR(50),
    IN p_department VARCHAR(50),
    IN p_salary INT
)
BEGIN
    INSERT INTO employees(id, emp_name, department, salary)
    VALUES (p_id, p_name, p_department, p_salary);
END //
DELIMITER ;
CALL InsertEmployee1(14, 'David', 'IT', 50000);

-- 2. Create a stored procedure to update salary based on id

DELIMITER //
CREATE PROCEDURE UpdateSalary1(
    IN p_id INT,
    IN p_salary INT
)
BEGIN
    UPDATE employees
    SET salary = p_salary
    WHERE id = p_id;
END //
DELIMITER ;
CALL UpdateSalary1(2, 30000);

-- 3. Write a trigger that updates stock when a new order is placed

DELIMITER //
CREATE TRIGGER UpdateStock
AFTER INSERT ON orders1
FOR EACH ROW
BEGIN
    UPDATE products1
    SET stock = stock - NEW.quantity
    WHERE product_id = NEW.product_id;
END //
DELIMITER ;

INSERT INTO orders1 VALUES (106, 1, 2, 3);
SELECT * FROM products1;

-- 4. Write a trigger that prevents deleting the last admin user

DELIMITER //
CREATE TRIGGER PreventLastAdminDelete
BEFORE DELETE ON users
FOR EACH ROW
BEGIN
    IF OLD.role = 'Admin'
       AND (SELECT COUNT(*) FROM users WHERE role = 'Admin') = 1
    THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Cannot delete the last admin user';
    END IF;
END //
DELIMITER ;

DELETE FROM users WHERE user_id = 2;
DELETE FROM users WHERE user_id = 1; 

-- 5. Create and call a stored procedure to fetch employees

DELIMITER //
CREATE PROCEDURE GetEmployees()
BEGIN
    SELECT * FROM employees;
END //
DELIMITER ;
CALL GetEmployees();

-- 6. Drop a procedure and trigger

DROP PROCEDURE IF EXISTS GetEmployees;
DROP TRIGGER IF EXISTS PreventLastAdminDelete;
