-- 1. Employees with salary greater than average salary
SELECT * FROM employees WHERE salary > (SELECT AVG(salary) FROM employees);

-- 2. Products with price higher than cheapest order
SELECT * FROM products WHERE price > (SELECT MIN(price) FROM orders);

-- 3. Customers who placed orders
SELECT * FROM customers WHERE customer_id IN (SELECT customer_id FROM orders);

-- 4. Subquery inside SELECT for order count
SELECT customer_name,(SELECT COUNT(*) FROM orders WHERE orders.customer_id = customers.customer_id) AS total_orders FROM customers;

-- 5. Highest salary in each department (Correlated Subquery)
SELECT * FROM employees e1 WHERE salary = ( SELECT MAX(salary) FROM employees e2 WHERE e1.department_id = e2.department_id );

-- 6. Check if product exists
SELECT EXISTS (SELECT * FROM products WHERE product_name = 'Laptop') AS product_exists;
